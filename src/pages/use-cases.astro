---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Use Cases" description="See how teams apply AutoVideo mock previews across industries.">
  <section class="hero">
    <div class="container">
      <span class="badge">Use cases</span>
      <h1>One prompt, many industries.</h1>
      <p>AutoVideo adapts to marketing, education, product, and storytelling needs.</p>
    </div>
  </section>

  <section class="section">
    <div class="container grid">
      <div class="card">
        <h3>Product launches</h3>
        <p>Mock a launch video with highlights, feature shots, and CTA.</p>
      </div>
      <div class="card">
        <h3>Explainers</h3>
        <p>Show complex topics with a structured script and clear visuals.</p>
      </div>
      <div class="card">
        <h3>Brand campaigns</h3>
        <p>Create a storytelling arc aligned with brand tone.</p>
      </div>
      <div class="card">
        <h3>Social teasers</h3>
        <p>Auto-cut to multiple aspect ratios for mock previews.</p>
      </div>
      <div class="card">
        <h3>Training content</h3>
        <p>Generate lesson scripts, chapters, and on-screen text.</p>
      </div>
      <div class="card">
        <h3>Event highlights</h3>
        <p>Summarize key moments with dynamic pacing suggestions.</p>
      </div>
    </div>
  </section>
</BaseLayout>
