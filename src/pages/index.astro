---
import MainLayout from '../layouts/MainLayout.astro';
import Hero from '../components/Hero.astro';
---

<MainLayout title="Auto Video | AI Video Builder" description="AI website to create complete videos from prompts.">
  <Hero />

  <section class="grid">
    <article class="card">
      <h3>Fully Automated Pipeline</h3>
      <p>From idea to final export with script writing, visual planning, voice-over style, and timing.</p>
    </article>
    <article class="card">
      <h3>No Login Required</h3>
      <p>Open the site, paste your prompt, and instantly preview a generated video concept.</p>
    </article>
    <article class="card">
      <h3>Built for Teams</h3>
      <p>Use it for marketing, product explainers, onboarding, social stories, and ads.</p>
    </article>
  </section>
</MainLayout>
