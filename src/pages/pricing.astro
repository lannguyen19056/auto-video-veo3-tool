---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Pricing | Auto Video">
  <h1>Simple Pricing</h1>
  <p>Start with demos and mock generation for free. Upgrade only when ready.</p>
  <section class="grid">
    <article class="card"><h3>Free</h3><p>Unlimited mock runs, public demo library, no login required.</p></article>
    <article class="card"><h3>Team</h3><p>Brand presets, shared prompt workspace, campaign templates.</p></article>
    <article class="card"><h3>Enterprise</h3><p>Custom pipeline design, dedicated support, private deployment options.</p></article>
  </section>
</MainLayout>
