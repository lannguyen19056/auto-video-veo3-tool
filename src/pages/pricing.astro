---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Pricing" description="Flexible mock packages for teams exploring AI video creation.">
  <section class="hero">
    <div class="container">
      <span class="badge">Transparent pricing</span>
      <h1>Mock packages for every team size.</h1>
      <p>All plans include mock previews, storyboard export, and access to the demo library.</p>
    </div>
  </section>

  <section class="section">
    <div class="container pricing">
      <div class="card">
        <h3>Starter</h3>
        <div class="price">$49</div>
        <p>Perfect for quick concept validation.</p>
        <ul>
          <li>2 mock builds / month</li>
          <li>Storyboard + script</li>
          <li>Email support</li>
        </ul>
        <a class="button secondary" href="/contact">Request access</a>
      </div>
      <div class="card" style="border-color: rgba(94, 234, 212, 0.4);">
        <h3>Creator</h3>
        <div class="price">$149</div>
        <p>For teams iterating weekly.</p>
        <ul>
          <li>10 mock builds / month</li>
          <li>Audio preview mix</li>
          <li>Priority feedback</li>
        </ul>
        <a class="button primary" href="/create">Start a mock</a>
      </div>
      <div class="card">
        <h3>Studio</h3>
        <div class="price">Custom</div>
        <p>For agencies and production houses.</p>
        <ul>
          <li>Unlimited mock builds</li>
          <li>Custom style presets</li>
          <li>Dedicated success lead</li>
        </ul>
        <a class="button secondary" href="/contact">Talk to us</a>
      </div>
    </div>
  </section>
</BaseLayout>
