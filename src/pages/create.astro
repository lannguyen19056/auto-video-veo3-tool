---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Create Video | Auto Video">
  <section class="panel">
    <h1>Create Your Next Video</h1>
    <p>Join us in automating video creation. Share your requirements and we'll help you get started with Auto Video.</p>
    <form action="mailto:admin@autovideo.videi" method="post" enctype="text/plain">
      <label>
        Your Name
        <input name="name" type="text" required />
      </label>
      <label>
        Email Address
        <input name="email" type="email" required />
      </label>
      <label>
        Video Project Description
        <textarea name="message" rows="6" required placeholder="Describe the type of video you want to create and your goals"></textarea>
      </label>
      <button class="button" type="submit">Request Early Access</button>
    </form>
    <p style="color: var(--muted); margin-top: 1rem; font-size: 0.9rem;">We'll get back to you within 24 hours to discuss your project needs.</p>
  </section>
</MainLayout>
