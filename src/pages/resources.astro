---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Resources" description="Guides and templates for building AI video prompts.">
  <section class="hero">
    <div class="container">
      <span class="badge">Resources</span>
      <h1>Guides, templates, and prompt ideas.</h1>
      <p>Use these resources to craft clearer prompts and stronger mock videos.</p>
    </div>
  </section>

  <section class="section">
    <div class="container grid">
      <div class="card">
        <h3>Prompt blueprint</h3>
        <p>Structure a prompt with goal, audience, tone, and CTA.</p>
        <a class="button secondary" href="/create">View template</a>
      </div>
      <div class="card">
        <h3>Storyboard checklist</h3>
        <p>Ensure every scene has a clear purpose and transition.</p>
        <a class="button secondary" href="/workflow">View checklist</a>
      </div>
      <div class="card">
        <h3>Audio direction guide</h3>
        <p>Match voice, pacing, and music to emotional tone.</p>
        <a class="button secondary" href="/create">See examples</a>
      </div>
      <div class="card">
        <h3>Demo inspiration</h3>
        <p>Browse a growing list of demo prompts and outputs.</p>
        <a class="button secondary" href="/demos">Browse demos</a>
      </div>
    </div>
  </section>
</BaseLayout>
