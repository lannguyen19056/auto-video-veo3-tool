---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Workflow" description="Discover the AutoVideo AI workflow that maps prompts to full video drafts.">
  <section class="hero">
    <div class="container">
      <span class="badge">AI workflow</span>
      <h1>The AutoVideo creative pipeline.</h1>
      <p>Every step is mocked so you can review before committing to production.</p>
    </div>
  </section>

  <section class="section">
    <div class="container grid">
      <div class="card">
        <h3>Prompt parser</h3>
        <p>Understands audience, tone, duration, and platform constraints.</p>
      </div>
      <div class="card">
        <h3>Story architect</h3>
        <p>Builds a narrative arc with openings, tension, and a CTA.</p>
      </div>
      <div class="card">
        <h3>Visual planner</h3>
        <p>Creates a shot list, camera movement, and visual references.</p>
      </div>
      <div class="card">
        <h3>Audio stylizer</h3>
        <p>Suggests voice talent, pacing, and music mood.</p>
      </div>
      <div class="card">
        <h3>Mock renderer</h3>
        <p>Combines placeholders into a shareable preview deck.</p>
      </div>
      <div class="card">
        <h3>Feedback sync</h3>
        <p>Collects approvals and pushes updates back into the script.</p>
      </div>
    </div>
  </section>
</BaseLayout>
