---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="About" description="Learn the story behind AutoVideo and our AI-first creative mission.">
  <section class="hero">
    <div class="container hero-grid">
      <div>
        <span class="badge">Our mission</span>
        <h1>We help teams visualize ideas instantly.</h1>
        <p>
          AutoVideo exists to remove the friction between a creative concept and a shareable preview.
          We build AI workflows that respect creative direction and save hours of manual prep.
        </p>
      </div>
      <div class="hero-card">
        <h3>What we believe</h3>
        <ul>
          <li>Great videos start with clear alignment.</li>
          <li>Mock drafts are faster than endless meetings.</li>
          <li>AI should accelerate, not replace, creativity.</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-title">
        <span>Our values</span>
        <h2>Built for creative teams, producers, and agencies.</h2>
      </div>
      <div class="grid">
        <div class="card">
          <h3>Creative clarity</h3>
          <p>We make sure every stakeholder sees the same vision early.</p>
        </div>
        <div class="card">
          <h3>Speed without chaos</h3>
          <p>Mock builds happen fast, but stay organized and structured.</p>
        </div>
        <div class="card">
          <h3>Human direction</h3>
          <p>Your prompt is the director. AutoVideo simply executes the draft.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
