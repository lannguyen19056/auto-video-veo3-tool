---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Contact | Auto Video">
  <h1>Contact Us</h1>
  <section class="panel">
    <p>Have questions about Auto Video? We'd love to hear from you. Send us a message and our team will get back to you typically within 1-2 business days.</p>
    <form action="mailto:admin@autovideo.video" method="post" enctype="text/plain">
      <label>
        Name
        <input name="name" type="text" required />
      </label>
      <label>
        Email
        <input name="email" type="email" required />
      </label>
      <label>
        Project goals
        <textarea name="message" rows="5" required placeholder="Tell us about your video automation needs and goals"></textarea>
      </label>
      <button class="button" type="submit">Send Message</button>
    </form>
  </section>
</MainLayout>
